      {
        "involves": "session",
        "what": "会话处于恢复模式且存在可恢复的历史消息"
      },
      {
        "involves": "config",
        "what": "至少一个扩展在初始化后会暴露资源项"
      }
    ],
    "trigger": {
      "method": "start",
      "target": "InteractiveMode",
      "type": "service_call"
