{
  "source_commit": "e904b11e7b4fb97105712a951ffb72b2572df69f",
  "bug_summary": "Ghostty 检测未覆盖 GHOSTTY_RESOURCES_DIR 环境变量，tmux 内无法识别为支持 kitty inline images",
  "module": "terminal-image",
  "action": "detectCapabilities",
  "fix_summary": "在 Ghostty 检测条件中增加 process.env.GHOSTTY_RESOURCES_DIR 判断",
  "test_type": "regression",
  "boundary": "service",
  "wrong_behavior": "tmux 内 TERM_PROGRAM 非 ghostty 时不识别 Ghostty，图片能力缺失",
  "correct_behavior": "GHOSTTY_RESOURCES_DIR 存在时识别为 Ghostty，启用 kitty 图片支持",
  "data_dependencies": [
    "config"
  ],
  "test_spec": {
    "preconditions": [
      {
        "what": "tmux 环境，GHOSTTY_RESOURCES_DIR 已设置",
        "involves": "config"
      }
    ],
    "trigger": {
      "type": "service_call",
      "target": "terminal-image",
      "method": "detectCapabilities"
    },
    "args": {
      "env": {
        "type": "object",
        "required": true,
        "allowed": null
      }
    },
    "outputs": {
      "capabilities": "object"
    },
    "assertions": [
      {
        "what": "GHOSTTY_RESOURCES_DIR 触发 kitty 图片",
        "type": "return_value",
        "expected": "capabilities.images === 'kitty'"
      },
      {
        "what": "trueColor 启用",
        "type": "return_value",
        "expected": "capabilities.trueColor === true"
      }
    ]
  }
}