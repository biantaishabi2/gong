{
  "action": "buildBaseOptions",
  "boundary": "service",
  "bug_summary": "buildBaseOptions 未透传 cacheRetention，导致上游缓存保留策略配置失效",
  "correct_behavior": "返回基础选项时正确包含并透传 options.cacheRetention",
  "data_dependencies": [
    "config"
  ],
  "fix_summary": "在返回的基础选项中新增 cacheRetention: options?.cacheRetention 透传",
  "module": "ai",
  "source_commit": "8f7ef85833c3e590ed862e76a25f209fd9b28623",
  "test_spec": {
    "args": {
      "apiKey": {
        "allowed": null,
        "required": false,
        "type": "string"
      },
      "model": {
        "allowed": null,
        "required": true,
        "type": "json"
      },
      "options": {
        "allowed": null,
        "required": false,
        "type": "json"
      }
    },
    "assertions": [
      {
        "expected": "stream_options.cacheRetention === options.cacheRetention",
        "type": "return_value",
        "what": "当 options.cacheRetention 提供时，返回结果包含同值 cacheRetention"
      },
      {
        "expected": "stream_options.cacheRetention === undefined",
        "type": "return_value",
        "what": "未提供 options.cacheRetention 时，返回结果的 cacheRetention 为 undefined"
      }
    ],
    "outputs": {
      "cacheRetention": "string",
      "stream_options": "json"
    },
    "preconditions": [
      {
        "involves": "config",
        "what": "存在可用模型对象且包含 maxTokens 配置"
      }
    ],
    "trigger": {
      "method": "buildBaseOptions",
      "target": "simple-options",
      "type": "service_call"
    }
  },
  "test_type": "regression",
  "wrong_behavior": "返回基础选项时丢失 options.cacheRetention"
}