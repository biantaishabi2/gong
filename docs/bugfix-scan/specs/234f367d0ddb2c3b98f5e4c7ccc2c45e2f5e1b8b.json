{
  "source_commit": "234f367d0ddb2c3b98f5e4c7ccc2c45e2f5e1b8b",
  "bug_summary": "/new 命令仅在 sessionFile 为空时生成新文件，通过 --session 指定文件后 /new 继续复用旧文件",
  "module": "session-manager",
  "action": "newSession",
  "fix_summary": "移除 !this.sessionFile 条件检查，改为始终生成新文件；保留 --session 指定的路径在初始化时使用；清空 labelsById 缓存",
  "test_type": "regression",
  "boundary": "service",
  "wrong_behavior": "/new 后 sessionFile 不变，新会话数据写入旧文件覆盖已有内容",
  "correct_behavior": "/new 后生成新 sessionFile 路径，旧文件保留，新会话写入新文件",
  "data_dependencies": [
    "file"
  ],
  "test_spec": {
    "preconditions": [
      {
        "what": "会话持久化开启（persist=true），当前有活跃会话文件",
        "involves": "file"
      }
    ],
    "trigger": {
      "type": "service_call",
      "target": "session-manager",
      "method": "newSession"
    },
    "args": {},
    "outputs": {
      "newSessionFile": "string",
      "oldSessionFile": "string"
    },
    "assertions": [
      {
        "what": "/new 后 sessionFile 路径改变",
        "type": "return_value",
        "expected": "newSessionFile !== oldSessionFile"
      },
      {
        "what": "labelsById 缓存被清空",
        "type": "db_state",
        "expected": "labelsById.size === 0"
      },
      {
        "what": "--session 指定的路径仅用于初始加载",
        "type": "return_value",
        "expected": "初始 sessionFile === explicitPath"
      }
    ]
  }
}