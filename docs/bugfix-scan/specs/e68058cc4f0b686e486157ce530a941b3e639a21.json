  "data_dependencies": [
    "state"
  ],
  "test_spec": {
    "preconditions": [
      {
        "what": "扩展上下文已创建，初始模型为 A",
        "involves": "state"
      }
    ],
    "trigger": {
      "type": "service_call",
      "target": "extensions-runner",
      "method": "createContext"
    },
    "args": {},
    "outputs": {
      "model": "object"
    },
    "assertions": [
      {
        "what": "模型切换后 ctx.model 返回新模型",
        "type": "return_value",
        "expected": "ctx.model === newModel after switch"
      },
      {
        "what": "使用 getter 而非固化值",
        "type": "return_value",
        "expected": "Object.getOwnPropertyDescriptor(ctx, 'model').get exists"
      }
    ]
  }
