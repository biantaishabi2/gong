          }
        ],
        "trigger": {
          "method": "cleanup",
          "target": "ProcessTerminal",
          "type": "service_call"
        }
      },
      "test_type": "regression",
      "wrong_behavior": "恢复 raw mode 时未先暂停 stdin，缓冲 Ctrl+D 可能被 shell 消费并关闭 SSH 会话。"
