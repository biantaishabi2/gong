            "type": "io_state",
            "what": "退出后 raw mode 恢复为 this.wasRaw"
          }
        ],
        "outputs": {
          "raw_mode_restored": "bool",
          "ssh_session_alive": "bool",
          "stdin_paused": "bool"
        },
        "preconditions": [
