#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
WORK_DIR="${PWD}"

export GONG_WORKDIR="${WORK_DIR}"
export GONG_ENTRY="${GONG_ENTRY:-bin/gong}"

legacy_entry_migration_cmd() {
  if [[ "$#" -eq 0 ]]; then
    echo "bin/gong help"
    return
  fi

  local args=("$@")

  if [[ "${args[0]}" == "cli" ]]; then
    if [[ "${#args[@]}" -eq 1 ]]; then
      echo "bin/gong help"
      return
    fi

    args=("${args[@]:1}")
  fi

  if [[ "${args[0]}" == "--help" || "${args[0]}" == "-h" ]]; then
    echo "bin/gong help"
    return
  fi

  echo "bin/gong ${args[*]}"
}

otp_version="${GONG_RUNTIME_OTP_OVERRIDE:-$(
  erl -noshell -eval 'io:format("~s",[erlang:system_info(otp_release)]), halt().' 2>/dev/null || true
)}"
elixir_version="${GONG_RUNTIME_ELIXIR_OVERRIDE:-$(
  elixir -e 'IO.write(System.version())' 2>/dev/null || true
)}"

if [[ -z "${otp_version}" ]]; then
  otp_version="unknown"
fi

if [[ -z "${elixir_version}" ]]; then
  elixir_version="unknown"
fi

runtime_reason=""

if [[ "${otp_version}" =~ ^([0-9]+) ]]; then
  otp_major="${BASH_REMATCH[1]}"
  if (( otp_major < 25 )); then
    runtime_reason="OTP 版本过低（${otp_major}）"
  fi
else
  runtime_reason="无法解析 OTP 版本（${otp_version}）"
fi

if [[ -z "${runtime_reason}" ]]; then
  if [[ "${elixir_version}" =~ ^([0-9]+)\.([0-9]+) ]]; then
    elixir_major="${BASH_REMATCH[1]}"
    elixir_minor="${BASH_REMATCH[2]}"
    if (( elixir_major < 1 || (elixir_major == 1 && elixir_minor < 14) )); then
      runtime_reason="Elixir 版本过低（${elixir_version}）"
    fi
  else
    runtime_reason="无法解析 Elixir 版本（${elixir_version}）"
  fi
fi

if [[ -n "${runtime_reason}" ]]; then
  if [[ "${GONG_LEGACY_ENTRY:-0}" == "1" ]]; then
    migration_cmd="$(legacy_entry_migration_cmd "$@")"
    legacy_entry_name="${GONG_ENTRY:-bin/gong-cli}"
    echo "[DEPRECATION] 旧入口 \`${legacy_entry_name}\` 已弃用，将在下个主版本升级为错误。" >&2
    echo "[DEPRECATION] 请迁移到 \`${migration_cmd}\`。" >&2
  fi

  echo "[ERROR] 运行时依赖不满足。" >&2
  echo "[ERROR] 要求: Erlang/OTP >= 25，Elixir >= 1.14" >&2
  echo "[ERROR] 当前: OTP ${otp_version}，Elixir ${elixir_version}" >&2
  echo "[ERROR] 详情: ${runtime_reason}" >&2
  echo "[HINT] 请升级 Erlang/OTP 与 Elixir，或使用 include_erts=true 的 release 包。" >&2
  exit 10
fi

cd "${ROOT_DIR}"

# 优先使用 release（零编译启动），fallback 到 mix run
RELEASE_BIN="${ROOT_DIR}/_build/prod/rel/gong/bin/gong"
if [[ -x "${RELEASE_BIN}" ]]; then
  # release eval 不接受 argv，通过环境变量传递 CLI 参数
  export GONG_CLI_ARGV
  GONG_CLI_ARGV=$(printf '%s\n' "$@")
  exec "${RELEASE_BIN}" eval '
    Application.ensure_all_started(:gong)
    args = System.get_env("GONG_CLI_ARGV", "") |> String.split("\n", trim: true)
    System.halt(Gong.CLI.run(args, entry: System.get_env("GONG_ENTRY"), legacy_entry: System.get_env("GONG_LEGACY_ENTRY") == "1"))
  '
else
  exec mix run -e 'System.halt(Gong.CLI.run(System.argv(), entry: System.get_env("GONG_ENTRY"), legacy_entry: System.get_env("GONG_LEGACY_ENTRY") == "1"))' -- "$@"
fi
